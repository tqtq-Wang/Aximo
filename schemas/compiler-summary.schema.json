{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://axiom-lang.dev/schemas/compiler-summary.schema.json",
  "title": "Axiom Compiler Summary",
  "description": "Module-level semantic summary for Axiom tooling, documentation, and AI workflows.",
  "type": "object",
  "required": [
    "schema_version",
    "module",
    "imports",
    "exports",
    "types",
    "diagnostics",
    "breaking_changes"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "module": {
      "type": "string"
    },
    "imports": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "exports": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ExportEntry"
      }
    },
    "types": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/TypeEntry"
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/DiagnosticEntry"
      }
    },
    "breaking_changes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/BreakingChange"
      }
    }
  },
  "$defs": {
    "ExportEntry": {
      "type": "object",
      "required": [
        "name",
        "kind",
        "visibility",
        "signature",
        "effects",
        "errors",
        "async",
        "calls"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "function",
            "struct",
            "enum",
            "trait",
            "const"
          ]
        },
        "visibility": {
          "type": "string",
          "enum": [
            "public",
            "internal",
            "private"
          ]
        },
        "signature": {
          "type": "string"
        },
        "effects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "async": {
          "type": "boolean"
        },
        "calls": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "TypeField": {
      "type": "object",
      "required": [
        "name",
        "type"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "visibility": {
          "type": "string",
          "enum": [
            "public",
            "internal",
            "private"
          ]
        }
      },
      "additionalProperties": false
    },
    "TypeVariant": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "TypeEntry": {
      "type": "object",
      "required": [
        "name",
        "kind"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "struct",
            "enum",
            "newtype",
            "alias"
          ]
        },
        "fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TypeField"
          }
        },
        "variants": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TypeVariant"
          }
        },
        "target": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "DiagnosticEntry": {
      "type": "object",
      "required": [
        "level",
        "code",
        "message",
        "location"
      ],
      "properties": {
        "level": {
          "type": "string",
          "enum": [
            "error",
            "warning",
            "info"
          ]
        },
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "location": {
          "type": "object",
          "required": [
            "file",
            "line",
            "column"
          ],
          "properties": {
            "file": {
              "type": "string"
            },
            "line": {
              "type": "integer",
              "minimum": 1
            },
            "column": {
              "type": "integer",
              "minimum": 1
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "BreakingChange": {
      "type": "object",
      "required": [
        "kind",
        "symbol",
        "message"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "removed_export",
            "signature_changed",
            "effect_expanded",
            "enum_variant_removed"
          ]
        },
        "symbol": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
