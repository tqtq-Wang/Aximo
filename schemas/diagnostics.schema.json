{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://axiom-lang.dev/schemas/diagnostics.schema.json",
  "title": "Axiom Diagnostics",
  "description": "Structured diagnostics emitted by Axiom tooling.",
  "type": "object",
  "required": [
    "schema_version",
    "diagnostics"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Diagnostic"
      }
    }
  },
  "$defs": {
    "Position": {
      "type": "object",
      "required": [
        "line",
        "column"
      ],
      "properties": {
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "column": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "Location": {
      "type": "object",
      "required": [
        "file",
        "start",
        "end"
      ],
      "properties": {
        "file": {
          "type": "string"
        },
        "start": {
          "$ref": "#/$defs/Position"
        },
        "end": {
          "$ref": "#/$defs/Position"
        }
      },
      "additionalProperties": false
    },
    "RelatedLocation": {
      "type": "object",
      "required": [
        "message",
        "location"
      ],
      "properties": {
        "message": {
          "type": "string"
        },
        "location": {
          "$ref": "#/$defs/Location"
        }
      },
      "additionalProperties": false
    },
    "Diagnostic": {
      "type": "object",
      "required": [
        "level",
        "code",
        "message",
        "location"
      ],
      "properties": {
        "level": {
          "type": "string",
          "enum": [
            "error",
            "warning",
            "info"
          ]
        },
        "code": {
          "type": "string",
          "pattern": "^[A-Z][0-9]{3}$"
        },
        "message": {
          "type": "string"
        },
        "location": {
          "$ref": "#/$defs/Location"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "help": {
          "type": "string"
        },
        "related": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/RelatedLocation"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
